@WebApi_HostAddress = http://localhost:5143
@LicensePlate = KR12345
@DriverToken = TU_WKLEJ_ACCESS_TOKEN_KIEROWCY_Z_ODPOWIEDZI_LOGIN
@AdminToken = TU_WKLEJ_ACCESS_TOKEN_ADMINA_Z_ODPOWIEDZI_LOGIN

# ============================================================
# JAK KORZYSTAC Z TEGO PLIKU
# ============================================================
# 1. Uruchomić WebApi na http://localhost:5143.
# 2. Wykonać login kierowcy i skopiuj accessToken do zmiennej DriverToken.
# 3. Dla endpointow z [AUTH] wymagany jest naglowek Authorization.
# 4. Testowa tablica rejestracyjna z seedera: KR12345.
# 5. Publiczna platnosc oznacza sesje jako oplacona bez konta kierowcy.
#    Do testu salda uzywać sekcji "Platnosci i konto kierowcy".


# ============================================================
# 0. AUTORYZACJA
# ============================================================

###
# Login zarejestrowanego kierowcy.
# Po wykonaniu skopiuj accessToken do DriverToken na gorze pliku.
POST {{WebApi_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "jan.kowalski@parking.local",
  "password": "User@123!"
}

###
# Login administratora.
# Potrzebne tylko do sekcji pomocniczej "Admin / bramki".
POST {{WebApi_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@parking.local",
  "password": "Admin@123!"
}

###
# [AUTH] Sprawdzenie aktualnie zalogowanego uzytkownika.
GET {{WebApi_HostAddress}}/api/auth/me
Accept: application/json
Authorization: Bearer {{DriverToken}}

###
# Odswiezenie tokenu.
# Wklej accessToken i refreshToken z odpowiedzi logowania/refresh.
POST {{WebApi_HostAddress}}/api/auth/refresh
Content-Type: application/json

{
  "accessToken": "TU_WKLEJ_ACCESS_TOKEN",
  "refreshToken": "TU_WKLEJ_REFRESH_TOKEN"
}

###
# [AUTH] Uniewaznienie refresh tokenu.
POST {{WebApi_HostAddress}}/api/auth/revoke
Content-Type: application/json
Authorization: Bearer {{DriverToken}}

"TU_WKLEJ_REFRESH_TOKEN"


###
# Historia sesji pojazdu po numerze rejestracyjnym.
GET {{WebApi_HostAddress}}/api/public/vehicles/{{LicensePlate}}/sessions
Accept: application/json

###
# Aktualna aktywna sesja pojazdu po numerze rejestracyjnym.
GET {{WebApi_HostAddress}}/api/public/vehicles/{{LicensePlate}}/current-session
Accept: application/json

###
# Platnosc anonimowa za aktualna sesje.
# Uwaga: oznacza sesje jako oplacona, ale nie korzysta z salda konta kierowcy.
POST {{WebApi_HostAddress}}/api/public/vehicles/{{LicensePlate}}/pay-current-session
Accept: application/json


# ============================================================
# 2. ZAREJESTROWANI KIEROWCY - POJAZDY
# ============================================================
# Wszystkie endpointy w tej sekcji wymagaja DriverToken.

###
# [AUTH] Rejestracja pojazdu kierowcy.
# Wymagane: numer rejestracyjny i marka.
POST {{WebApi_HostAddress}}/api/drivers/vehicles
Content-Type: application/json
Authorization: Bearer {{DriverToken}}

{
  "licensePlate": "{{LicensePlate}}",
  "brand": "BMW"
}

###
# [AUTH] Lista pojazdow zalogowanego kierowcy.
GET {{WebApi_HostAddress}}/api/drivers/vehicles
Accept: application/json
Authorization: Bearer {{DriverToken}}


# ============================================================
# 3. ZAREJESTROWANI KIEROWCY - SESJE POJAZDOW
# ============================================================

###
# [AUTH] Historia sesji konkretnego pojazdu kierowcy.
# Kierowca moze przegladac tylko swoje pojazdy.
GET {{WebApi_HostAddress}}/api/drivers/vehicles/{{LicensePlate}}/sessions
Accept: application/json
Authorization: Bearer {{DriverToken}}

###
# [AUTH] Aktualna sesja konkretnego pojazdu kierowcy.
GET {{WebApi_HostAddress}}/api/drivers/vehicles/{{LicensePlate}}/current-session
Accept: application/json
Authorization: Bearer {{DriverToken}}


# ============================================================
# 4. ZAREJESTROWANI KIEROWCY - RABATY
# ============================================================
# Rabaty trzeba aktywowac recznie.
# RegistrationBonus: dodatkowe 60 minut darmowego parkowania, aktywny 30 dni.
# LoyaltyDiscount: obnizka ceny po przekroczeniu 100 sesji, aktywny 30 dni.

###
# [AUTH] Lista rabatow kierowcy.
GET {{WebApi_HostAddress}}/api/drivers/discounts
Accept: application/json
Authorization: Bearer {{DriverToken}}

###
# [AUTH] Aktywacja rabatu za rejestracje.
POST {{WebApi_HostAddress}}/api/drivers/discounts/activate-registration
Accept: application/json
Authorization: Bearer {{DriverToken}}

###
# [AUTH] Aktywacja rabatu lojalnosciowego.
# Wymaga co najmniej 100 sesji parkowania kierowcy.
POST {{WebApi_HostAddress}}/api/drivers/discounts/activate-loyalty
Accept: application/json
Authorization: Bearer {{DriverToken}}


# ============================================================
# 5. ZAREJESTROWANI KIEROWCY - KONTO I PLATNOSCI
# ============================================================
# Konto mozna zasilic z wyprzedzeniem i potem placic z salda.
# Jesli RegistrationBonus obejmuje aktualna sesje, platnosc powinna byc darmowa
# i zwrocic amount = 0 bez zmniejszania salda.

###
# [AUTH] Odczyt salda konta kierowcy.
GET {{WebApi_HostAddress}}/api/drivers/account
Accept: application/json
Authorization: Bearer {{DriverToken}}

###
# [AUTH] Doladowanie konta kierowcy.
POST {{WebApi_HostAddress}}/api/drivers/account/topup
Content-Type: application/json
Authorization: Bearer {{DriverToken}}

{
  "amount": 50
}

###
# [AUTH] Platnosc za aktualna sesje pojazdu z konta kierowcy.
# To jest glowny endpoint do sprawdzania pobierania z salda i rabatow.
POST {{WebApi_HostAddress}}/api/drivers/vehicles/{{LicensePlate}}/pay-current-session
Accept: application/json
Authorization: Bearer {{DriverToken}}

###
# Dziala tak samo jak pay-current-session dla zarejestrowanego kierowcy.
POST {{WebApi_HostAddress}}/api/drivers/vehicles/{{LicensePlate}}/pay-from-account
Accept: application/json
Authorization: Bearer {{DriverToken}}


# ============================================================
# 6. PRZYKLADOWY SCENARIUSZ TESTOWY
# ============================================================
# 1. Login kierowcy.
# 2. Skopiuj accessToken
# 3. Zarejestruj pojazd albo upewnij sie, ze {{LicensePlate}} nalezy do kierowcy.
# 4. Sprawdz aktualna sesje.
# 5. Opcjonalnie aktywuj RegistrationBonus.
# 6. Sprawdz saldo.
# 7. Doladuj konto.
# 8. Zaplac przez endpoint kierowcy.
# 9. Sprawdz saldo ponownie.


# ============================================================
# 7. ADMIN / BRAMKI / KAMERY - POMOCNICZE
# ============================================================
# Ta sekcja nie jest czescia wymagan kierowcow, ale pomaga przygotowac dane.

###
# [ADMIN] Lista bramek.
GET {{WebApi_HostAddress}}/api/gates?page=1&size=10
Accept: application/json
Authorization: Bearer {{AdminToken}}

###
# [ADMIN] Utworzenie bramki.
POST {{WebApi_HostAddress}}/api/gates
Content-Type: application/json
Authorization: Bearer {{AdminToken}}

{
  "name": "Entry Gate 2",
  "type": "Entry",
  "location": "Main Gate"
}

###
# [AUTH] Dodanie odczytu kamery do bramki.
# Podmien gateId na istniejace ID bramki.
POST {{WebApi_HostAddress}}/api/gates/11111111-aaaa-4444-8888-111111111111/captures
Content-Type: application/json
Authorization: Bearer {{DriverToken}}

{
  "licensePlate": "{{LicensePlate}}",
  "brand": "BMW",
  "color": "Black",
  "imagePath": "images/car1.jpg"
}

###
# Lista odczytow kamery dla bramki.
GET {{WebApi_HostAddress}}/api/gates/11111111-aaaa-4444-8888-111111111111/captures?page=1&size=10
Accept: application/json


###
# [AUTH] Usuniecie odczytu kamery.
# Podmien gateId i captureId na wartosci z odpowiedzi GET captures.
DELETE {{WebApi_HostAddress}}/api/gates/11111111-aaaa-4444-8888-111111111111/captures/00000000-0000-0000-0000-000000000000
Accept: application/json
Authorization: Bearer {{DriverToken}}
